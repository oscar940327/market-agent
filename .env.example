SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Main Research Report LLM.
# rule_based = no LLM cost. llm = use the provider below to rewrite/explain reports.
MARKET_AGENT_ANALYST_MODE=llm
MARKET_AGENT_LLM_PROVIDER=openrouter
MARKET_AGENT_LLM_MODEL=openai/gpt-4.1
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://127.0.0.1:8001
OPENROUTER_APP_NAME=market-agent

# Optional fallback if MARKET_AGENT_LLM_PROVIDER=openai.
OPENAI_API_KEY=

# Optional news extractor.
# Keep rule_based until the news pipeline is stable. llm classifies each news item.
NEWS_EXTRACTOR_MODE=rule_based
NEWS_LLM_PROVIDER=openrouter
NEWS_LLM_MODEL=openai/gpt-5.4-mini
NEWS_LLM_ESCALATION_ENABLED=false
NEWS_LLM_ESCALATION_MODEL=openai/gpt-5.5

# Optional direct DeepSeek fallback if NEWS_LLM_PROVIDER=deepseek.
DEEPSEEK_API_KEY=

# Optional social data providers for Step 6.9.
# Leave disabled until each provider is implemented and its access/cost is verified.
SOCIAL_PROVIDERS_ENABLED=false
X_BEARER_TOKEN=
THREADS_ACCESS_TOKEN=
STOCKTWITS_ACCESS_TOKEN=
