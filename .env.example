SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Main Research Report LLM.
# rule_based = no LLM cost. llm = use the provider below to rewrite/explain reports.
MARKET_AGENT_ANALYST_MODE=llm
MARKET_AGENT_LLM_PROVIDER=openrouter
MARKET_AGENT_LLM_MODEL=openai/gpt-4.1
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://127.0.0.1:8001
OPENROUTER_APP_NAME=market-agent

# Hybrid question router. Clear questions remain rule-based and use no LLM token.
# Low-confidence questions use OpenRouter and must return validated structured JSON.
MARKET_AGENT_ROUTER_MODE=hybrid
MARKET_AGENT_ROUTER_PROVIDER=openrouter
# Leave empty to reuse MARKET_AGENT_LLM_MODEL.
MARKET_AGENT_ROUTER_MODEL=
MARKET_AGENT_ROUTER_CONFIDENCE_THRESHOLD=0.8

# Research Report quality review.
# deterministic = checklist only, no token cost.
# hybrid = only deterministic failures use OpenRouter reviewer/reviser.
# semantic = always score report quality and revise when needed, up to 3 times.
MARKET_AGENT_REPORT_REVIEW_MODE=hybrid
MARKET_AGENT_REPORT_REVIEW_PROVIDER=openrouter
MARKET_AGENT_REPORT_REVIEW_MODEL=openai/gpt-5.4-mini
MARKET_AGENT_REPORT_REVIEW_MAX_ITERATIONS=3

# Optional fallback if MARKET_AGENT_LLM_PROVIDER=openai.
OPENAI_API_KEY=

# Optional news extractor.
# Keep rule_based until the news pipeline is stable. llm classifies each news item.
NEWS_EXTRACTOR_MODE=rule_based
NEWS_LLM_PROVIDER=openrouter
NEWS_LLM_MODEL=openai/gpt-5.4-mini
NEWS_LLM_ESCALATION_ENABLED=false
NEWS_LLM_ESCALATION_MODEL=openai/gpt-5.5

# Optional pipeline alert emails.
# Uses Gmail SMTP with a Google App Password. Only sends when enabled.
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_PROVIDER=gmail
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
GMAIL_APP_PASSWORD=

# Optional direct DeepSeek fallback if NEWS_LLM_PROVIDER=deepseek.
DEEPSEEK_API_KEY=

# Optional social data providers for Step 6.9.
# Leave disabled until each provider is implemented and its access/cost is verified.
SOCIAL_PROVIDERS_ENABLED=false
X_BEARER_TOKEN=
THREADS_ACCESS_TOKEN=
STOCKTWITS_ACCESS_TOKEN=
